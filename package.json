{
  "name": "baan-c-vscode",
  "displayName": "Baan C VSCode",
  "description": "Complete language support for Baan C / Infor LN (3GL & 4GL): syntax highlighting, snippets, formatting, block diagnostics, naming hints, 980+ built-in completions, signature help, references, rename, folding, hovers, symbols, and more",
  "version": "1.0.4",
  "publisher": "AnonymousGCA",
  "icon": "icons/baanc-dark.webp",
  "repository": {
    "type": "git",
    "url": "https://github.com/GABRYCA/baan-c-vscode"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Formatters",
    "Linters"
  ],
  "keywords": [
    "baan",
    "baan c",
    "infor",
    "ln",
    "3gl",
    "4gl",
    "erp"
  ],
  "activationEvents": [
    "onLanguage:baanc"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "baanc",
        "aliases": [
          "Baan C",
          "baanc",
          "BaanC"
        ],
        "extensions": [
          ".bc",
          ".cl",
          ".bcl",
          ".script"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/baanc-light-icon.webp",
          "dark": "./icons/baanc-dark-icon.webp"
        }
      }
    ],
    "grammars": [
      {
        "language": "baanc",
        "scopeName": "source.baanc",
        "path": "./syntaxes/baanc.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "baanc",
        "path": "./snippets/baanc.json"
      }
    ],
    "configuration": {
      "title": "Baan C",
      "properties": {
        "baanc.indentSize": {
          "type": "integer",
          "default": 4,
          "minimum": 1,
          "maximum": 16,
          "description": "Number of spaces per indent level when formatting"
        },
        "baanc.formatOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically format the document on save"
        },
        "baanc.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable block-matching and structural diagnostics"
        },
        "baanc.diagnostics.strictComments": {
          "type": "boolean",
          "default": true,
          "description": "Ignore | and /* */ comments when analyzing blocks"
        },
        "baanc.diagnostics.namingConventions": {
          "type": "boolean",
          "default": true,
          "description": "Hint when identifiers do not follow Baan/Infor LN naming conventions (lowercase, dots, expressive names). Uses Hint severity only — not errors."
        },
        "baanc.diagnostics.namingArgPrefixes": {
          "type": "boolean",
          "default": false,
          "description": "Also hint when function arguments lack i./o./io. prefixes (off by default — can be noisy)"
        },
        "baanc.completion.includeSql": {
          "type": "boolean",
          "default": true,
          "description": "Include SQL / embedded-select keywords in completions"
        },
        "baanc.completion.includePreprocessor": {
          "type": "boolean",
          "default": true,
          "description": "Include preprocessor directives in completions"
        },
        "baanc.completion.include4gl": {
          "type": "boolean",
          "default": true,
          "description": "Include common 4GL section names in completions"
        },
        "baanc.completion.includeBuiltins": {
          "type": "boolean",
          "default": true,
          "description": "Include built-in Baan C / Infor LN API functions in completions (db.*, strip$, message, http.*, curl.*, …)"
        },
        "baanc.completion.includeErrors": {
          "type": "boolean",
          "default": true,
          "description": "Include database / ES error constants (ELOCKED, EDUPL, ENOREC, …) in completions"
        }
      }
    },
    "commands": [
      {
        "command": "baanc.formatDocument",
        "title": "Baan C: Format Document"
      },
      {
        "command": "baanc.runDiagnostics",
        "title": "Baan C: Run Diagnostics"
      },
      {
        "command": "baanc.insertTransactionTemplate",
        "title": "Baan C: Insert Transaction + Select Template"
      },
      {
        "command": "baanc.insertSelectTemplate",
        "title": "Baan C: Insert Select Template"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "resourceLangId == baanc",
          "command": "baanc.formatDocument",
          "group": "1_modification"
        },
        {
          "when": "resourceLangId == baanc",
          "command": "baanc.insertSelectTemplate",
          "group": "1_modification@2"
        },
        {
          "when": "resourceLangId == baanc",
          "command": "baanc.insertTransactionTemplate",
          "group": "1_modification@3"
        }
      ],
      "commandPalette": [
        {
          "command": "baanc.formatDocument",
          "when": "editorLangId == baanc"
        },
        {
          "command": "baanc.runDiagnostics",
          "when": "editorLangId == baanc"
        },
        {
          "command": "baanc.insertTransactionTemplate",
          "when": "editorLangId == baanc"
        },
        {
          "command": "baanc.insertSelectTemplate",
          "when": "editorLangId == baanc"
        }
      ]
    },
    "configurationDefaults": {
      "[baanc]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "editor.detectIndentation": false,
        "editor.wordBasedSuggestions": "allDocuments",
        "editor.suggest.localityBonus": true,
        "editor.suggest.showWords": true,
        "editor.quickSuggestions": {
          "other": true,
          "comments": false,
          "strings": false
        },
        "editor.acceptSuggestionOnEnter": "on",
        "editor.suggestSelection": "first",
        "editor.parameterHints.enabled": true,
        "editor.folding": true,
        "files.trimTrailingWhitespace": true
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "package": "node esbuild.js --production",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0"
  }
}