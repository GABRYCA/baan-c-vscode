      "check.input:",
      "\t$0"
    ],
    "description": "4GL check.input: subsection"
  },
  "4GL choice section": {
    "prefix": "choice.",
    "body": [
      "choice.${1:cont.process}:",
      "\ton.choice:",
      "\t\t$0"
    ],
    "description": "4GL choice.<command>: section"
  },
  "Error check ELOCKED": {
    "prefix": "elocked",
    "body": [
      "if db.error() = ELOCKED then",
      "\t$0",
      "endif"
    ],
    "description": "Check for ELOCKED database error"
  }
}