{
  "If then endif": {
    "prefix": "if",
    "body": [
      "if ${1:condition} then",
      "\t$0",
      "endif"
    ],
    "description": "IF ... THEN ... ENDIF"
  },
  "If then else endif": {
    "prefix": "ife",
    "body": [
      "if ${1:condition} then",
      "\t$2",
      "else",
      "\t$0",
      "endif"
    ],
    "description": "IF ... THEN ... ELSE ... ENDIF"
  },
  "If elif else endif": {
    "prefix": "ifel",
    "body": [
      "if ${1:condition1} then",
      "\t$2",
      "elif ${3:condition2} then",
      "\t$4",
      "else",
      "\t$0",
      "endif"
    ],
    "description": "IF ... ELIF ... ELSE ... ENDIF"
  },
  "While endwhile": {
    "prefix": "while",
    "body": [
      "while ${1:condition}",
      "\t$0",
      "endwhile"
    ],
    "description": "WHILE ... ENDWHILE"
  },
  "For endfor": {
    "prefix": "for",
    "body": [
      "for ${1:i} = ${2:1} to ${3:10}",
      "\t$0",
      "endfor"
    ],
    "description": "FOR ... TO ... ENDFOR"
  },
  "For step endfor": {
    "prefix": "fors",
    "body": [
      "for ${1:i} = ${2:1} to ${3:100} step ${4:2}",
      "\t$0",
      "endfor"
    ],
    "description": "FOR ... TO ... STEP ... ENDFOR"
  },
  "Repeat until": {
    "prefix": "repeat",
    "body": [
      "repeat",
      "\t$0",
      "until ${1:condition}"
    ],
    "description": "REPEAT ... UNTIL"
  },
  "On case": {
    "prefix": "oncase",
    "body": [
      "on case ${1:expression}",
      "case ${2:value}:",
      "\t$3",
      "\tbreak",
      "default:",
      "\t$0",
      "endcase"
    ],
    "description": "ON CASE ... CASE ... DEFAULT ... ENDCASE"
  },
  "Function void": {
    "prefix": "func",
    "body": [
      "function ${1:name}(${2})",
      "{",
      "\t$0",
      "}"
    ],
    "description": "FUNCTION (void) with braces"
  },
  "Function typed": {
    "prefix": "funcl",
    "body": [
      "function ${1|long,double,string,void|} ${2:name}(${3})",
      "{",
      "\t$0",
      "\treturn(${4})",
      "}"
    ],
    "description": "Typed FUNCTION with return"
  },
  "Select block": {
    "prefix": "select",
    "body": [
      "select ${1:*}",
      "from ${2:table}",
      "where ${3:condition}",
      "selectdo",
      "\t$0",
      "selectempty",
      "\t| no records",
      "endselect"
    ],
    "description": "Embedded SQL SELECT ... SELECTDO ... ENDSELECT"
  },
  "Select full": {
    "prefix": "selectf",
    "body": [
      "select ${1:*}",
      "from ${2:table}",
      "where ${3:condition}",
      "selectdo",
      "\t$4",
      "selecteos",
      "\t$5",
      "selectempty",
      "\t$6",
      "selecterror",
      "\tmessage(\"Error %d\", db.error)",
      "\tbreak",
      "endselect"
    ],
    "description": "Full embedded SQL with all branches"
  },
  "Domain declaration": {
    "prefix": "domain",
    "body": [
      "domain ${1:domain.name} ${2:varName}"
    ],
    "description": "DOMAIN variable declaration"
  },
  "Table declaration": {
    "prefix": "table",
    "body": [
      "table t${1:tccom001}"
    ],
    "description": "TABLE declaration (name starts with t)"
  },
  "Long declaration": {
    "prefix": "long",
    "body": [
      "long ${1:varName}"
    ],
    "description": "LONG variable"
  },
  "String declaration": {
    "prefix": "string",
    "body": [
      "string ${1:varName}(${2:30})"
    ],
    "description": "STRING variable with length"
  },
  "Boolean declaration": {
    "prefix": "boolean",
    "body": [
      "boolean ${1:varName}"
    ],
    "description": "BOOLEAN variable"
  },
  "Double declaration": {
    "prefix": "double",
    "body": [
      "double ${1:varName}"
    ],
    "description": "DOUBLE variable"
  },
  "Extern long": {
    "prefix": "extern",
    "body": [
      "extern ${1|long,double,string,boolean|} ${2:varName}"
    ],
    "description": "EXTERN variable declaration"
  },
  "Define macro": {
    "prefix": ["#define", "define"],
    "body": [
      "#define ${1:NAME} ${2:value}"
    ],
    "description": "#define macro (wordPattern treats #NAME as one word so no ##)"
  },
  "Undef macro": {
    "prefix": ["#undef", "undef"],
    "body": [
      "#undef ${1:NAME}"
    ],
    "description": "#undef macro"
  },
  "Ifdef block": {
    "prefix": ["#ifdef", "ifdef"],
    "body": [
      "#ifdef ${1:MACRO}",
      "\t$0",
      "#endif"
    ],
    "description": "#ifdef ... #endif"
  },
  "Ifndef block": {
    "prefix": ["#ifndef", "ifndef"],
    "body": [
      "#ifndef ${1:MACRO}",
      "\t$0",
      "#endif"
    ],
    "description": "#ifndef ... #endif"
  },
  "If preprocessor": {
    "prefix": ["#if", "ppif"],
    "body": [
      "#if ${1:expression}",
      "\t$0",
      "#endif"
    ],
    "description": "#if ... #endif"
  },
  "Include quotes": {
    "prefix": ["#include", "include"],
    "body": [
      "#include \"${1:itxadv0000}\""
    ],
    "description": "#include \"file\" (application / redirected)"
  },
  "Include angle": {
    "prefix": ["#include<", "include<"],
    "body": [
      "#include <${1:filename}>"
    ],
    "description": "#include <system header>"
  },
  "Pragma": {
    "prefix": ["#pragma", "pragma"],
    "body": [
      "#pragma ${1|debug,nowarnings,warnings,notransactions,strict_boolean,sticky,used|} ${2}"
    ],
    "description": "#pragma compiler option"
  },
  "Ident": {
    "prefix": ["#ident", "ident"],
    "body": [
      "#ident \"@(#)${1:Identification of object}\""
    ],
    "description": "#ident object identification"
  },
  "4GL declaration section": {
    "prefix": "declaration",
    "body": [
      "declaration:",
      "\ttable t${1:tccom001}",
      "\tlong ${2:ret}",
      "\t$0"
    ],
    "description": "4GL declaration: section"
  },
  "4GL before.program": {
    "prefix": ["before.program", "before."],
    "body": [
      "before.program:",
      "\t$0"
    ],
    "description": "4GL before.program: section"
  },
  "4GL after.program": {
    "prefix": "after.program",
    "body": [
      "after.program:",
      "\t$0"
    ],
    "description": "4GL after.program: section"
  },
  "4GL before.checks": {
    "prefix": ["before.checks", "before.ch"],
    "body": [
      "before.checks:",
      "\t$0"
    ],
    "description": "4GL before.checks: subsection"
  },
  "4GL when.field.changes": {
    "prefix": "when.field.changes",
    "body": [
      "when.field.changes:",
      "\t$0"
    ],
    "description": "4GL when.field.changes: subsection"
  },
  "4GL field section": {
    "prefix": "field.",
    "body": [
      "field.${1:table.field}:",
      "\tbefore.display:",
      "\t\t$0",
      "\tafter.input:",
      "\t\t"
    ],
    "description": "4GL field.<name>: section"
  },
  "4GL main.table.io": {
    "prefix": "main.table.io",
    "body": [
      "main.table.io:",
      "\tbefore.write:",
      "\t\t$0",
      "\tafter.read:",
      "\t\t"
    ],
    "description": "4GL main.table.io: section"
  },
  "Message": {
    "prefix": "message",
    "body": [
      "message(\"${1:text}\")"
    ],
    "description": "message() call"
  },
  "Commit transaction": {
    "prefix": "commit",
    "body": [
      "commit.transaction()"
    ],
    "description": "commit.transaction()"
  },
  "Abort transaction": {
    "prefix": "abort",
    "body": [
      "abort.transaction()"
    ],
    "description": "abort.transaction()"
  },
  "Db retry point": {
    "prefix": "retry",
    "body": [
      "db.retry.point()",
      "$0"
    ],
    "description": "db.retry.point()"
  },
  "Transaction with select for update": {
    "prefix": "txselect",
    "body": [
      "db.retry.point()",
      "long ${1:ret} = 0",
      "select ${2:*}",
      "from ${3:table}",
      "for update",
      "where ${4:condition}",
      "selectdo",
      "\t$0",
      "\t${1:ret} = db.update(${5:table.id}, db.retry)",
      "selectempty",
      "\t| no records",
      "endselect",
      "if ${1:ret} = 0 then",
      "\tcommit.transaction()",
      "else",
      "\tabort.transaction()",
      "endif"
    ],
    "description": "db.retry.point + select for update + commit/abort"
  },
  "DAL get and save object": {
    "prefix": "dalgs",
    "body": [
      "long ${1:ret}",
      "${1:ret} = dal.get.object(\"${2:class.name}\", ${3:true})",
      "if ${1:ret} = 0 then",
      "\tdal.set.field(\"${4:field}\", ${5:value})",
      "\t${1:ret} = dal.save.object(\"${2:class.name}\")",
      "endif",
      "$0"
    ],
    "description": "dal.get.object + set field + dal.save.object"
  },
  "HTTP GET pattern": {
    "prefix": "httpget",
    "body": [
      "long ${1:resp} = http.get(\"${2:https://example.com/api}\")",
      "if http.response.statuscode(${1:resp}) = 200 then",
      "\t$0",
      "else",
      "\tmessage(\"HTTP error: %s\", http.response.error_message(${1:resp}))",
      "endif",
      "http.response.delete(${1:resp})"
    ],
    "description": "http.get with status check and cleanup"
  },
  "cURL download string": {
    "prefix": "curlget",
    "body": [
      "string ${1:data}(4096)",
      "long ${2:ret} = curl.download.string(\"${3:https://example.com}\", ${1:data})",
      "if ${2:ret} = 0 then",
      "\t$0",
      "else",
      "\tmessage(\"cURL error: %s\", curl.strerror$(${2:ret}))",
      "endif"
    ],
    "description": "curl.download.string with error handling"
  },
  "Function extern long": {
    "prefix": "funcex",
    "body": [
      "function extern long ${1:name}(",
      "\t${2:ref long i.arg}",
      ")",
      "{",
      "\t$0",
      "\treturn(0)",
      "}"
    ],
    "description": "function extern long with ref argument"
  },
  "On case string": {
    "prefix": "oncases",
    "body": [
      "on case ${1:expression}",
      "case \"${2:value}\":",
      "\t$3",
      "\tbreak",
      "default:",
      "\t$0",
      "endcase"
    ],
    "description": "ON CASE with string case labels"
  },
  "Prototype": {
    "prefix": "proto",
    "body": [
      "prototype ${1|long,double,string,void|} ${2:name}(${3})"
    ],
    "description": "function prototype declaration"
  },
  "SQL parse exec fetch": {
    "prefix": "sqlpf",
    "body": [
      "long ${1:sql.id} = sql.parse(\"${2:select * from ttccom001}\")",
      "sql.select.bind(${1:sql.id}, ${3:1}, ${4:var})",
      "sql.exec(${1:sql.id})",
      "while sql.fetch(${1:sql.id}) = 0",
      "\t$0",
      "endwhile",
      "sql.close(${1:sql.id})"
    ],
    "description": "Dynamic SQL: parse, bind, exec, fetch, close"
  },
  "Query extend where": {
    "prefix": "qext",
    "body": [
      "query.extend.where(\"${1:ttccom001.cuno = :cuno}\")",
      "$0"
    ],
    "description": "query.extend.where extension"
  },
  "4GL after.field": {
    "prefix": "after.field",
    "body": [
